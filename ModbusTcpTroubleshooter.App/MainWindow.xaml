<Window x:Class="ModbusTcpTroubleshooter.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Modbus TCP Troubleshooter" Height="790" Width="1280" MinHeight="700" MinWidth="1120"
        Background="#F2F4F1">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Modbus TCP Troubleshooter" FontSize="24" FontWeight="SemiBold" Foreground="#17312B" />
                <TextBlock Text="{Binding Status}" Foreground="#5B665F" Margin="0,3,0,0" />
            </StackPanel>
            <Button DockPanel.Dock="Right" Content="Exportar caso" Command="{Binding SaveCaseCommand}" HorizontalAlignment="Right" />
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D5DDD6" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,12,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Caso" FontSize="16" FontWeight="SemiBold" Foreground="#17312B" Margin="0,0,0,8" />
                        <TextBlock Text="Nome" />
                        <TextBox Text="{Binding CaseName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Modo operacional" FontSize="16" FontWeight="SemiBold" Foreground="#17312B" Margin="0,10,0,8" />
                        <ComboBox ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}" />

                        <StackPanel Visibility="{Binding IsClientMode, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Client substitute" FontSize="16" FontWeight="SemiBold" Foreground="#17312B" Margin="0,10,0,8" />
                            <TextBlock Text="IP do server alvo" />
                            <TextBox Text="{Binding TargetIp, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Porta" />
                            <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Unit ID" />
                            <TextBox Text="{Binding UnitId, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Taxa de scan (ms)" />
                            <TextBox Text="{Binding ScanRateMs, UpdateSourceTrigger=PropertyChanged}" />

                            <WrapPanel>
                                <Button Content="Leitura unica" Command="{Binding ReadOnceCommand}" />
                                <Button Content="Iniciar scan" Command="{Binding StartClientScanCommand}" />
                                <Button Content="Parar scan" Command="{Binding StopClientScanCommand}" />
                            </WrapPanel>

                            <TextBlock Text="Escrita FC06" FontSize="16" FontWeight="SemiBold" Foreground="#17312B" Margin="0,10,0,8" />
                            <TextBlock Text="Endereco HR" />
                            <TextBox Text="{Binding WriteAddress, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Valor" />
                            <TextBox Text="{Binding WriteValue, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Content="Escrever HR" Command="{Binding WriteRegisterCommand}" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsServerMode, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Server substitute" FontSize="16" FontWeight="SemiBold" Foreground="#17312B" Margin="0,10,0,8" />
                            <TextBlock Text="IP local para escutar" />
                            <TextBox Text="{Binding LocalIp, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Porta" />
                            <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Unit ID" />
                            <TextBox Text="{Binding UnitId, UpdateSourceTrigger=PropertyChanged}" />
                            <WrapPanel>
                                <Button Content="Iniciar servidor" Command="{Binding StartServerCommand}" />
                                <Button Content="Parar servidor" Command="{Binding StopServerCommand}" />
                            </WrapPanel>
                            <TextBlock Text="Use 1502 para teste local. A porta 502 pode exigir permissao/admin." TextWrapping="Wrap" Foreground="#6D756E" />
                        </StackPanel>

                        <Button Content="TESTE COMPLETO" Command="{Binding StartFullTestCommand}" Margin="0,16,8,4" Background="#17312B" Foreground="White" FontWeight="SemiBold" />
                        <Button Content="Limpar timeline" Command="{Binding ClearTimelineCommand}" Margin="0,4,8,8" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="#D5DDD6" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.05*" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="1.25*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.35*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D5DDD6" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,8,8"
                            Visibility="{Binding IsClientMode, Converter={StaticResource BoolToVisibility}}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Mapa do client" FontSize="16" FontWeight="SemiBold" Foreground="#17312B" VerticalAlignment="Center" Margin="0,0,16,0" />
                                <Button Content="Adicionar linha" Command="{Binding AddClientMapRowCommand}" />
                                <Button Content="Remover linha" Command="{Binding RemoveClientMapRowCommand}" />
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding ClientMapRows}" SelectedItem="{Binding SelectedClientMapRow}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="45" />
                                    <DataGridTextColumn Header="Nome" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="130" />
                                    <DataGridTemplateColumn Header="FC" Width="160">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Function}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding Functions}" SelectedItem="{Binding Function, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Endereco" Binding="{Binding StartAddress, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                    <DataGridTextColumn Header="Qtd" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="55" />
                                    <DataGridTextColumn Header="Ultimo valor" Binding="{Binding LastValue}" Width="*" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding LastStatus}" Width="150" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Hora" Binding="{Binding LastReadAt}" Width="90" IsReadOnly="True" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D5DDD6" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,8,8"
                            Visibility="{Binding IsServerMode, Converter={StaticResource BoolToVisibility}}">
                        <TabControl>
                            <TabItem Header="Configurar faixas">
                                <DockPanel Margin="0,8,0,0">
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Faixas expostas pelo server" FontSize="16" FontWeight="SemiBold" Foreground="#17312B" VerticalAlignment="Center" Margin="0,0,16,0" />
                                        <Button Content="Adicionar faixa" Command="{Binding AddServerRangeCommand}" />
                                        <Button Content="Remover faixa" Command="{Binding RemoveServerRangeCommand}" />
                                        <Button Content="Aplicar mapa" Command="{Binding ApplyServerMapCommand}" />
                                    </StackPanel>
                                    <DataGrid ItemsSource="{Binding ServerMapRanges}" SelectedItem="{Binding SelectedServerMapRange}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="45" />
                                            <DataGridTextColumn Header="Prefixo" Binding="{Binding NamePrefix, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                                            <DataGridTemplateColumn Header="Tipo" Width="145">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Type}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding TypeOptions}" SelectedItem="{Binding Type, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Inicio" Binding="{Binding StartAddress, UpdateSourceTrigger=PropertyChanged}" Width="65" />
                                            <DataGridTextColumn Header="Qtd" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="55" />
                                            <DataGridTextColumn Header="Valor inicial" Binding="{Binding InitialValue, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                                            <DataGridCheckBoxColumn Header="Inc" Binding="{Binding IncrementValue}" Width="45" />
                                            <DataGridCheckBoxColumn Header="R/W" Binding="{Binding Writable}" Width="50" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </TabItem>
                            <TabItem Header="Visualizar mapa">
                                <DockPanel Margin="0,8,0,0">
                                    <TextBlock DockPanel.Dock="Top" Text="Mapa efetivo do server simulado" FontSize="16" FontWeight="SemiBold" Foreground="#17312B" Margin="0,0,0,8" />
                                    <DataGrid ItemsSource="{Binding ServerPoints}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="130" />
                                            <DataGridTextColumn Header="Endereco" Binding="{Binding Address}" Width="80" />
                                            <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="*" />
                                            <DataGridTextColumn Header="Valor" Binding="{Binding Value}" Width="80" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </TabItem>
                        </TabControl>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="#D5DDD6" Margin="0,0,0,8" />

                    <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#D5DDD6" BorderThickness="1" CornerRadius="6" Padding="10" Margin="8,0,0,8">
                        <TabControl>
                            <TabItem Header="Todos">
                                <DockPanel Margin="0,8,0,0">
                                    <TextBlock DockPanel.Dock="Top" Text="Diagnosticos" FontSize="16" FontWeight="SemiBold" Foreground="#17312B" Margin="0,0,0,8" />
                                    <DataGrid ItemsSource="{Binding Diagnostics}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Hora" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="75" />
                                            <DataGridTextColumn Header="Nivel" Binding="{Binding Severity}" Width="75" />
                                            <DataGridTextColumn Header="Mensagem" Binding="{Binding Message}" Width="*" />
                                            <DataGridTextColumn Header="Recomendacao" Binding="{Binding Recommendation}" Width="220" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </TabItem>
                            <TabItem Header="Avisos importantes">
                                <DockPanel Margin="0,8,0,0">
                                    <TextBlock DockPanel.Dock="Top" Text="Resumo de ocorrencias importantes" FontSize="16" FontWeight="SemiBold" Foreground="#17312B" Margin="0,0,0,8" />
                                    <DataGrid ItemsSource="{Binding ImportantWarnings}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Qtd" Binding="{Binding Count}" Width="45" />
                                            <DataGridTextColumn Header="Nivel" Binding="{Binding Severity}" Width="75" />
                                            <DataGridTextColumn Header="Primeira" Binding="{Binding FirstSeenAt, StringFormat=HH:mm:ss}" Width="75" />
                                            <DataGridTextColumn Header="Ultima" Binding="{Binding LastSeenAt, StringFormat=HH:mm:ss}" Width="75" />
                                            <DataGridTextColumn Header="Resumo" Binding="{Binding Title}" Width="220" />
                                            <DataGridTextColumn Header="Ultimo detalhe" Binding="{Binding LatestDetail}" Width="*" />
                                            <DataGridTextColumn Header="Recomendacao" Binding="{Binding Recommendation}" Width="260" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </TabItem>
                            <TabItem Header="Checklist">
                                <DockPanel Margin="0,8,0,0">
                                    <TextBlock DockPanel.Dock="Top" Text="Verificacoes automaticas" FontSize="16" FontWeight="SemiBold" Foreground="#17312B" Margin="0,0,0,8" />
                                    <DataGrid ItemsSource="{Binding VerificationChecks}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Item" Binding="{Binding Name}" Width="125" />
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="85" />
                                            <DataGridTextColumn Header="Detalhe" Binding="{Binding Detail}" Width="*" />
                                            <DataGridTextColumn Header="Hora" Binding="{Binding LastCheckedAt}" Width="75" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </TabItem>
                            <TabItem Header="Teste completo">
                                <DockPanel Margin="0,8,0,0">
                                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                        <WrapPanel Margin="0,0,0,8">
                                            <TextBlock Text="Varredura industrial guiada" FontSize="16" FontWeight="SemiBold" Foreground="#17312B" VerticalAlignment="Center" Margin="0,0,16,0" />
                                            <Button Content="Executar teste completo" Command="{Binding StartFullTestCommand}" />
                                            <Button Content="Exportar relatorio" Command="{Binding SaveFullTestReportCommand}" />
                                            <CheckBox Content="Varredura ativa da sub-rede" IsChecked="{Binding EnableActiveSubnetScan}" VerticalAlignment="Center" Margin="14,0,8,0" />
                                            <TextBlock Text="Timeout ms" VerticalAlignment="Center" Margin="8,0,4,0" />
                                            <TextBox Text="{Binding ActiveScanTimeoutMs, UpdateSourceTrigger=PropertyChanged}" Width="58" />
                                            <TextBlock Text="Concorrencia" VerticalAlignment="Center" Margin="8,0,4,0" />
                                            <TextBox Text="{Binding ActiveScanConcurrency, UpdateSourceTrigger=PropertyChanged}" Width="48" />
                                        </WrapPanel>
                                        <UniformGrid Columns="3" Margin="0,0,0,4">
                                            <Border Background="#EEF4EA" BorderBrush="#CAD8C5" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,6,6">
                                                <StackPanel>
                                                    <TextBlock Text="Status geral" Foreground="#5B665F" />
                                                    <TextBlock Text="{Binding FullTestOverallStatus}" FontSize="18" FontWeight="SemiBold" Foreground="#17312B" />
                                                    <TextBlock Text="{Binding FullTestScore}" Foreground="#5B665F" />
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#F4F0E6" BorderBrush="#DDD1B8" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,6,6">
                                                <StackPanel>
                                                    <TextBlock Text="Rede / hosts" Foreground="#5B665F" />
                                                    <TextBlock Text="{Binding FullTestNetworkSummary}" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="#17312B" />
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#EAF2F5" BorderBrush="#C7D8DF" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                                                <StackPanel>
                                                    <TextBlock Text="Modbus descoberto" Foreground="#5B665F" />
                                                    <TextBlock Text="{Binding FullTestModbusSummary}" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="#17312B" />
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>
                                        <UniformGrid Columns="2">
                                            <Border Background="#F6F7F3" BorderBrush="#D5DDD6" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,6,0">
                                                <StackPanel>
                                                    <TextBlock Text="Rotas / gateway" Foreground="#5B665F" />
                                                    <TextBlock Text="{Binding FullTestRouteSummary}" TextWrapping="Wrap" Foreground="#17312B" />
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#F6F7F3" BorderBrush="#D5DDD6" BorderThickness="1" CornerRadius="6" Padding="8">
                                                <StackPanel>
                                                    <TextBlock Text="Banda / carga" Foreground="#5B665F" />
                                                    <TextBlock Text="{Binding FullTestBandwidthSummary}" TextWrapping="Wrap" Foreground="#17312B" />
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>
                                    </StackPanel>
                                    <TabControl>
                                        <TabItem Header="Checklist">
                                            <Grid Margin="0,8,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="1.1*" />
                                                    <RowDefinition Height="6" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <DataGrid Grid.Row="0" ItemsSource="{Binding FullTestSteps}" SelectedItem="{Binding SelectedFullTestStep}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="#" Binding="{Binding Order}" Width="35" />
                                                        <DataGridTextColumn Header="Etapa" Binding="{Binding Name}" Width="155" />
                                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="85" />
                                                        <DataGridTextColumn Header="Objetivo" Binding="{Binding Objective}" Width="*" />
                                                        <DataGridTextColumn Header="Recomendacao" Binding="{Binding Recommendation}" Width="260" />
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                                <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch" Background="#D5DDD6" />
                                                <DockPanel Grid.Row="2" Margin="0,8,0,0">
                                                    <TextBlock DockPanel.Dock="Top" Text="Detalhe da etapa selecionada" FontWeight="SemiBold" Foreground="#17312B" Margin="0,0,0,4" />
                                                    <TextBox Text="{Binding SelectedFullTestStep.Result}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
                                                </DockPanel>
                                            </Grid>
                                        </TabItem>
                                        <TabItem Header="Dispositivos / rede">
                                            <DataGrid Margin="0,8,0,0" ItemsSource="{Binding NetworkDiscoveryRows}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="IP" Binding="{Binding Ip}" Width="120" />
                                                    <DataGridTextColumn Header="MAC" Binding="{Binding Mac}" Width="140" />
                                                    <DataGridTextColumn Header="Fonte" Binding="{Binding Source}" Width="150" />
                                                    <DataGridTextColumn Header="Papel provavel" Binding="{Binding RoleGuess}" Width="180" />
                                                    <DataGridTextColumn Header="Portas/Modbus" Binding="{Binding ModbusStatus}" Width="130" />
                                                    <DataGridTextColumn Header="Notas" Binding="{Binding Notes}" Width="*" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </TabItem>
                                        <TabItem Header="Relatorio">
                                            <DockPanel Margin="0,8,0,0">
                                                <TextBlock DockPanel.Dock="Top" Text="Relatorio final exportavel" FontWeight="SemiBold" Foreground="#17312B" Margin="0,0,0,4" />
                                                <TextBox Text="{Binding FullTestReport}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
                                            </DockPanel>
                                        </TabItem>
                                    </TabControl>
                                </DockPanel>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>

                <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch" Background="#D5DDD6" />

                <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D5DDD6" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,8,0,0">
                    <TabControl>
                        <TabItem Header="Modbus">
                            <DockPanel Margin="0,8,0,0">
                                <TextBlock DockPanel.Dock="Top" Text="Timeline Modbus TCP" FontSize="16" FontWeight="SemiBold" Foreground="#17312B" Margin="0,0,0,8" />
                                <DataGrid ItemsSource="{Binding Traffic}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Hora" Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Width="95" />
                                        <DataGridTextColumn Header="Direcao" Binding="{Binding Direction}" Width="115" />
                                        <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="145" />
                                        <DataGridTextColumn Header="TID" Binding="{Binding TransactionId}" Width="55" />
                                        <DataGridTextColumn Header="UID" Binding="{Binding UnitId}" Width="55" />
                                        <DataGridTextColumn Header="FC" Binding="{Binding FunctionCode}" Width="50" />
                                        <DataGridTextColumn Header="Addr" Binding="{Binding StartAddress}" Width="60" />
                                        <DataGridTextColumn Header="Qtd" Binding="{Binding Quantity}" Width="55" />
                                        <DataGridTextColumn Header="Resumo" Binding="{Binding Summary}" Width="*" />
                                        <DataGridTextColumn Header="Hex" Binding="{Binding Hex}" Width="260" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </TabItem>
                        <TabItem Header="TCP">
                            <DockPanel Margin="0,8,0,0">
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.7*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Interface" />
                                            <ComboBox ItemsSource="{Binding CaptureDevices}" SelectedItem="{Binding SelectedCaptureDevice}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                            <TextBlock Text="Protocolo" />
                                            <ComboBox ItemsSource="{Binding CaptureProtocols}" SelectedItem="{Binding SelectedCaptureProtocol}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                            <TextBlock Text="IP" />
                                            <TextBox Text="{Binding CaptureIp, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                            <TextBlock Text="Direcao IP" />
                                            <ComboBox ItemsSource="{Binding CaptureDirections}" SelectedItem="{Binding SelectedCaptureIpDirection}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="4" Margin="0,0,8,0">
                                            <TextBlock Text="Porta" />
                                            <TextBox Text="{Binding CapturePort, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="5" Margin="0,0,8,0">
                                            <TextBlock Text="Direcao porta" />
                                            <ComboBox ItemsSource="{Binding CaptureDirections}" SelectedItem="{Binding SelectedCapturePortDirection}" />
                                        </StackPanel>
                                        <WrapPanel Grid.Column="6" VerticalAlignment="Bottom">
                                            <Button Content="Atualizar interfaces" Command="{Binding RefreshCaptureDevicesCommand}" />
                                            <Button Content="Atualizar filtro" Command="{Binding ApplyCaptureFilterCommand}" />
                                            <Button Content="Iniciar captura" Command="{Binding StartNetworkCaptureCommand}" />
                                            <Button Content="Parar captura" Command="{Binding StopNetworkCaptureCommand}" />
                                        </WrapPanel>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1.6*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Filtro Source" />
                                            <TextBox Text="{Binding SourceColumnFilter, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                            <TextBlock Text="Filtro Destination" />
                                            <TextBox Text="{Binding DestinationColumnFilter, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                            <TextBlock Text="Filtro Protocol" />
                                            <TextBox Text="{Binding ProtocolColumnFilter, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                            <TextBlock Text="Filtro Info" />
                                            <TextBox Text="{Binding InfoColumnFilter, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="BPF gerado" />
                                            <TextBox Text="{Binding GeneratedCaptureFilter}" IsReadOnly="True" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Foreground="#6D756E" Text="{Binding QueuedPassivePackets, StringFormat=Captura passiva da interface. Pacotes pendentes na fila de UI: {0}}" />
                                </StackPanel>
                                <DataGrid ItemsSource="{Binding FilteredTcpTimeline}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal" MouseDoubleClick="TcpTimelineGrid_MouseDoubleClick">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="No." Binding="{Binding Number}" Width="55" />
                                        <DataGridTextColumn Header="Time" Binding="{Binding RelativeTime, StringFormat=0.000000}" Width="95" />
                                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="150" />
                                        <DataGridTextColumn Header="Destination" Binding="{Binding Destination}" Width="150" />
                                        <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="95" />
                                        <DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="70" />
                                        <DataGridTextColumn Header="Info" Binding="{Binding Info}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="2" Margin="0,10,0,0" Foreground="#6D756E"
                   Text="Client e Server agora sao configurados separadamente. O mapa do client suporta leitura unica e scan ritmado." />
    </Grid>
</Window>
